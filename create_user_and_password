#!/bin/bash

# ============================================================
# Configuration
# ============================================================
REMOTE_SERVER="serveurdechames@91.69.7.150"
REMOTE_PASSWORD="P@risienne75!"
REMOTE_FILE="/home/serveurdechames/users.json"
TIMEOUT=10

# ============================================================
# Génération login / password aléatoires
# ============================================================
generate_username() {
    local adjectives=("swift" "dark" "brave" "quiet" "wild" "sharp" "cool" "fast" "bold" "calm")
    local nouns=("wolf" "hawk" "bear" "fox" "lion" "tiger" "eagle" "shark" "lynx" "raven")
    local adj=${adjectives[$RANDOM % ${#adjectives[@]}]}
    local noun=${nouns[$RANDOM % ${#nouns[@]}]}
    local num=$((RANDOM % 9000 + 1000))
    echo "${adj}_${noun}_${num}"
}

generate_password() {
    tr -dc 'A-Za-z0-9!@#$%^&*()_+' </dev/urandom | head -c 16
}

# ============================================================
# Récupération IP publique
# ============================================================
get_public_ip() {
    local ip=""
    local services=(
        "https://api.ipify.org"
        "https://ifconfig.me"
        "https://icanhazip.com"
        "https://ipecho.net/plain"
    )

    for service in "${services[@]}"; do
        ip=$(curl -s --max-time "$TIMEOUT" "$service" 2>/dev/null | tr -d '[:space:]')
        if [[ $ip =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "$ip"
            return 0
        fi
    done

    echo "UNKNOWN"
    return 1
}

# ============================================================
# Création de l'utilisateur système
# ============================================================
create_user() {
    local username="$1"
    local password="$2"

    if id "$username" &>/dev/null; then
        echo "[WARN] L'utilisateur $username existe déjà, on regénère..."
        return 1
    fi

    useradd -m -s /bin/bash "$username" 2>/dev/null
    echo "$username:$password" | chpasswd 2>/dev/null

    if id "$username" &>/dev/null; then
        echo "[OK] Utilisateur $username créé."
        return 0
    else
        echo "[ERROR] Échec de la création de l'utilisateur."
        return 1
    fi
}

# ============================================================
# Écriture sur le serveur distant (avec lock pour éviter
# les race conditions lors des lancements simultanés)
# ============================================================
write_to_remote() {
    local username="$1"
    local password="$2"
    local ip="$3"
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Commande exécutée côté serveur distant
    # On utilise un lockfile pour gérer la concurrence
    local remote_cmd
    remote_cmd=$(cat <<'REMOTE'
set -e
LOCKFILE="/tmp/users_json.lock"
JSONFILE="PLACEHOLDER_FILE"

# Attente du lock (max 30s)
waited=0
while ! mkdir "$LOCKFILE" 2>/dev/null; do
    sleep 0.5
    waited=$((waited + 1))
    if [ $waited -ge 60 ]; then
        echo "LOCK_TIMEOUT"
        exit 1
    fi
done
trap 'rm -rf "$LOCKFILE"' EXIT

# Initialisation du fichier JSON si nécessaire
if [ ! -f "$JSONFILE" ] || [ ! -s "$JSONFILE" ]; then
    echo '{"users":[]}' > "$JSONFILE"
fi

# Injection de la nouvelle entrée
NEW_ENTRY='PLACEHOLDER_ENTRY'
python3 -c "
import json, sys

with open('$JSONFILE', 'r') as f:
    data = json.load(f)

entry = json.loads(sys.argv[1])
data['users'].append(entry)

with open('$JSONFILE', 'w') as f:
    json.dump(data, f, indent=2)
" "$NEW_ENTRY"

echo "SUCCESS"
REMOTE
)

    # Construction de l'entrée JSON
    local entry
    entry=$(printf '{"username":"%s","password":"%s","ip":"%s","created_at":"%s"}' \
        "$username" "$password" "$ip" "$timestamp")

    # Remplacement des placeholders
    remote_cmd="${remote_cmd/PLACEHOLDER_FILE/$REMOTE_FILE}"
    remote_cmd="${remote_cmd/PLACEHOLDER_ENTRY/$entry}"

    # Envoi via SSH avec sshpass + timeout
    local result
    result=$(sshpass -p "$REMOTE_PASSWORD" ssh \
        -o StrictHostKeyChecking=no \
        -o ConnectTimeout="$TIMEOUT" \
        -o BatchMode=no \
        "$REMOTE_SERVER" \
        "bash -s" <<< "$remote_cmd" 2>&1)

    if echo "$result" | grep -q "SUCCESS"; then
        echo "[OK] Données écrites sur le serveur distant."
        return 0
    else
        echo "[ERROR] Échec écriture distante: $result"
        return 1
    fi
}

# ============================================================
# Main
# ============================================================
main() {
    # Vérification root
    if [[ $EUID -ne 0 ]]; then
        echo "[ERROR] Ce script doit être lancé en root."
        exit 1
    fi

    # Vérification sshpass
    if ! command -v sshpass &>/dev/null; then
        echo "[INFO] Installation de sshpass..."
        apt-get install -y sshpass 2>/dev/null || \
        yum install -y sshpass 2>/dev/null || \
        { echo "[ERROR] Impossible d'installer sshpass."; exit 1; }
    fi

    # Vérification mot de passe configuré
    if [[ -z "$REMOTE_PASSWORD" ]]; then
        echo "[ERROR] Le mot de passe du serveur distant n'est pas défini dans le script."
        exit 1
    fi

    echo "============================================"
    echo " Démarrage du script de création d'utilisateur"
    echo "============================================"

    # Génération avec retry si username déjà pris
    local username password
    local max_attempts=5
    local attempt=0

    while [ $attempt -lt $max_attempts ]; do
        username=$(generate_username)
        password=$(generate_password)

        if create_user "$username" "$password"; then
            break
        fi
        attempt=$((attempt + 1))
    done

    if [ $attempt -ge $max_attempts ]; then
        echo "[ERROR] Impossible de créer un utilisateur après $max_attempts tentatives."
        exit 1
    fi

    # Récupération IP publique
    echo "[INFO] Récupération de l'IP publique..."
    local public_ip
    public_ip=$(get_public_ip)
    echo "[INFO] IP publique : $public_ip"

    # Écriture sur le serveur distant
    echo "[INFO] Écriture sur le serveur distant..."
    write_to_remote "$username" "$password" "$public_ip"

    echo "============================================"
    echo " Résumé"
    echo "============================================"
    echo " Username  : $username"
    echo " Password  : $password"
    echo " IP        : $public_ip"
    echo "============================================"
}

main "$@"
